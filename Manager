    def _start_auto_sync(self):
        def sync_loop():
            while True:
                delay = random.randint(1200, 1800)
                time.sleep(delay)
                try:
                    if self.badge_manager:
                        self.badge_manager.refresh()
                except:
                    pass

        threading.Thread(target=sync_loop, daemon=True).start()

    def _start_auto_update_checker(self):
        def update_loop():
            while True:
                time.sleep(3600)  # Кожну годину
                try:
                    # Перевіряємо і оновлюємо тихо (без сповіщень)
                    apply_update_if_available(force_notify=False)
                except:
                    pass

        threading.Thread(target=update_loop, daemon=True).start()

