def apply_update_if_available(force_notify=False):
    """
    Перевіряє наявність нової версії і автоматично завантажує її.
    Якщо force_notify=True — показує повідомлення про результат (успіх/помилка/немає оновлень).
    """
    try:
        response = requests.get(VERSION_URL, timeout=5)
        if response.status_code != 200:
            if force_notify:
                run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Не вдалося перевірити оновлення."))
            return

        latest_version = response.text.strip()
        if latest_version == __version__:
            if force_notify:
                run_on_ui_thread(lambda: BulletinHelper.show_info("ℹ️ Ви використовуєте останню версію плагіна."))
            return

        # Нова версія є — завантажуємо без зайвих питань
        if force_notify:
            run_on_ui_thread(lambda: BulletinHelper.show_info("🔄 Завантаження оновлення..."))

        # Завантажуємо новий код
        plugin_response = requests.get(PLUGIN_URL, timeout=10)
        if plugin_response.status_code != 200:
            if force_notify:
                run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Помилка завантаження оновлення."))
            return

        new_code = plugin_response.text
        cache_dir = ApplicationLoader.applicationContext.getCacheDir().getAbsolutePath()
        path = os.path.join(cache_dir, "plugin_update.py")
        with open(path, "w") as f:
            f.write(new_code)

        # Застосовуємо оновлення через систему плагінів
        from com.exteragram.messenger.plugins import PluginsController, PluginsConstants
        PluginsController.getInstance().engines.get(PluginsConstants.PYTHON).loadPluginFromFile(path, None, None)

        if force_notify:
            run_on_ui_thread(lambda: BulletinHelper.show_success("✅ Плагін оновлено! Перезапустіть клієнт."))
        else:
            # При тихому оновленні просто пишемо в лог (або в бота)
            send_to_bot(f"🔄 Плагін оновлено до версії {latest_version}")

    except Exception as e:
        if force_notify:
            run_on_ui_thread(lambda: BulletinHelper.show_error(f"❌ Помилка оновлення: {e}"))

