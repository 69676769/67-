    def _create_premium_header(self, context):
        try:
            container = FrameLayout(context)
            content = LinearLayout(context)
            content.setOrientation(1)

            particles_view = None
            hide_particles_runnable = [None]
            try:
                from org.telegram.ui.Components.Premium import StarParticlesView
                particles_view = StarParticlesView(context)
                particles_view.drawable.useRotate = False
                particles_view.drawable.isCircle = True
                particles_view.drawable.centerOffsetY = AndroidUtilities.dp(0)
                particles_view.drawable.minLifeTime = 2000
                particles_view.drawable.randLifeTime = 3000
                try:
                    particles_view.drawable.colorKey = Theme.key_premiumStarGradient2
                except:
                    pass
                particles_view.drawable.updateColors()
                particles_view.setVisibility(View.INVISIBLE)
                container.addView(particles_view, LayoutHelper.createFrame(340, 140, Gravity.CENTER | Gravity.TOP, 0, 10, 0, 0))
            except:
                pass

            user = None
            try:
                account = getattr(UserConfig, 'selectedAccount', 0)
                mc = MessagesController.getInstance(account)
                uc = UserConfig.getInstance(account)
                if mc and uc:
                    user = mc.getUser(uc.getClientUserId())
            except:
                pass

            img = BackupImageView(context)
            img.setRoundRadius(AndroidUtilities.dp(40))
            if user:
                img.setForUserOrChat(user, AvatarDrawable(user))
            else:
                img.setImageResource(R.drawable.msg_emoji)

            clicks = [0]
            last_click = [0]

            def on_logo_click(view):
                if particles_view:
                    try:
                        particles_view.setVisibility(View.VISIBLE)
                        particles_view.flingParticles(40)
                        if hide_particles_runnable[0]:
                            AndroidUtilities.cancelRunOnUIThread(hide_particles_runnable[0])

                        def _hide():
                            try:
                                particles_view.setVisibility(View.INVISIBLE)
                            except:
                                pass

                        hide_particles_runnable[0] = _hide
                        run_on_ui_thread(_hide, 3000)
                    except:
                        pass

                now = time.time()
                if now - last_click[0] > 1.0:
                    clicks[0] = 0
                clicks[0] += 1
                last_click[0] = now

                if clicks[0] == 3:
                    run_on_ui_thread(lambda: BulletinHelper.show_success("Створюй свою реальність! ✨"))
                    clicks[0] = 0

            img.setOnClickListener(OnClickListener(on_logo_click))
            content.addView(img, LayoutHelper.createLinear(80, 80, Gravity.CENTER_HORIZONTAL, 0, 24, 0, 12))

            title = TextView(context)
            title.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteBlackText))
            title.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 22)
            try:
                title.setTypeface(AndroidUtilities.getTypeface(AndroidUtilities.TYPEFACE_ROBOTO_MEDIUM))
            except:
                pass
            title.setText(f"⭐ Badge Manager v{__version__}")
            title.setGravity(Gravity.CENTER)
            content.addView(title, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_HORIZONTAL, 16, 0, 16, 4))

            subtitle = TextView(context)
            subtitle.setTextColor(Theme.getColor(Theme.key_windowBackgroundWhiteGrayText))
            subtitle.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 14)
            subtitle.setText("Керуй бейджами. Синхронізуй. Візуалізуй.")
            subtitle.setGravity(Gravity.CENTER)
            content.addView(subtitle, LayoutHelper.createLinear(-2, -2, Gravity.CENTER_HORIZONTAL, 24, 0, 24, 24))

            container.addView(content, LayoutHelper.createFrame(-1, -2, Gravity.CENTER))
            return container
        except:
            return None

