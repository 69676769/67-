                if resp.status_code == 200:
                    latest = resp.text.strip()
            except:
                pass

            status_text = f"⭐ Badge Manager\n\n"
            status_text += f"📌 Версія плагіна: {__version__}\n"
            status_text += f"📌 Остання версія: {latest}\n"
            status_text += f"📌 Оновлення: {'✅ Доступне' if latest != __version__ else '❌ Немає'}\n"
            status_text += f"📌 Бейджі: {'✅ Завантажені' if load_online_badges() else '❌ Немає'}\n"
