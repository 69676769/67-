def get_user_info(user_id):
    try:
        mc = MessagesController.getInstance(UserConfig.selectedAccount)
        user = mc.getUser(user_id)
        if user:
            name = f"{user.first_name or ''} {user.last_name or ''}".strip()
            username = f"@{user.username}" if user.username else ""
            return username, name
    except:
        pass
    return "", "Unknown"

def enrich_badges(badges):
    for entry in badges:
        uid = entry.get("user_id")
        if uid and ("username" not in entry or "name" not in entry):
            username, name = get_user_info(uid)
            if username:
                entry["username"] = username
            entry["name"] = name or "Unknown"
    return badges

