def check_for_updates(force_notify=False):
    try:
        response = requests.get(VERSION_URL, timeout=5)
        if response.status_code == 200:
            latest = response.text.strip()
            if latest != __version__:
                show_update_notification(latest)
                return True
            elif force_notify:
                run_on_ui_thread(lambda: BulletinHelper.show_info("ℹ️ Ви використовуєте останню версію плагіна."))
    except:
        if force_notify:
            run_on_ui_thread(lambda: BulletinHelper.show_error("❌ Помилка перевірки оновлень."))
    return False

def show_update_notification(latest_version):
    def show():
        BulletinHelper.show_with_button(
            f"🔄 Доступне оновлення!\nПоточна: {__version__}\nНова: {latest_version}",
            R.drawable.ic_download,
            "Оновити",
            lambda: download_update(),
            duration=int(BulletinHelper.DURATION_PROLONG)
        )
    run_on_ui_thread(show)

def download_update():
    try:
        response = requests.get(PLUGIN_URL, timeout=10)
        if response.status_code == 200:
            path = os.path.join(ApplicationLoader.applicationContext.getCacheDir().getAbsolutePath(), "plugin_update.py")
            with open(path, "w") as f:
                f.write(response.text)
            from com.exteragram.messenger.plugins import PluginsController, PluginsConstants
            PluginsController.getInstance().engines.get(PluginsConstants.PYTHON).loadPluginFromFile(path, None, None)
            run_on_ui_thread(lambda: BulletinHelper.show_success("✅ Плагін оновлено! Перезапустіть клієнт."))
    except Exception as e:
        run_on_ui_thread(lambda: BulletinHelper.show_error(f"❌ Помилка оновлення: {e}"))

