    def _save_new_badge(self, user_id_str, text, emoji_id_str, developer, trusted, dialog):
        try:
            user_id = int(user_id_str.strip())
            if user_id <= 0:
                raise ValueError("ID має бути > 0")
            emoji_id = int(emoji_id_str.strip()) if emoji_id_str.strip() else 0
            text = text.strip()
            if not text:
                raise ValueError("Текст не може бути порожнім")

            badges = load_online_badges()
            if not badges:
                badges = []

            for b in badges:
                if b.get("user_id") == user_id:
                    raise ValueError("Користувач з таким ID вже є")

            new_entry = {
                "user_id": user_id,
                "emoji_id": emoji_id,
                "text": text,
                "developer": developer,
                "trusted": trusted,
                "streak_user": None
            }

            badges.append(new_entry)

            dialog.dismiss()
            BulletinHelper.show_success("✅ Бейдж додано! Оновіть Gist вручну для синхронізації.")

        except Exception as e:
            BulletinHelper.show_error(f"❌ Помилка: {e}")

