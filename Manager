#  МЕНЕДЖЕР БЕЙДЖІВ (з кольором)
# ============================================

class BadgeManager:
    def __init__(self, plugin):
        self.plugin = plugin
        self.custom_badges = {}
        self.developer_users = set()
        self._hook_refs = []
        self.api_badge_source = None

    def setup(self):
        try:
            BadgesController = find_class("com.exteragram.messenger.badges.BadgesController")
            if BadgesController:
                instance = BadgesController.INSTANCE
                self.api_badge_source = get_private_field(instance, "apiBadgeSource")
                if self.api_badge_source:
                    self._setup_hooks()
                    self._load_badges()
        except:
            pass

    def _setup_hooks(self):
        try:
            ApiBadgeSource = find_class("com.exteragram.messenger.badges.source.ApiBadgeSource")
            if not ApiBadgeSource:
                return
            for method, hook_cls in [
                ("getBadge", _BadgeHook),
                ("isDeveloper", _DeveloperHook),
                ("canChangeBadge", _ChangeHook),
            ]:
                refs = self.plugin.hook_all_methods(ApiBadgeSource, method, hook_cls(self))
                if refs:
                    self._hook_refs.extend(refs)
        except:
            pass

    def _load_badges(self):
        global _last_hash
        try:
            cache = get_private_field(self.api_badge_source, "cache")
            if not cache:
                return
            BadgeDTO = find_class("com.exteragram.messenger.api.dto.BadgeDTO")
            BadgeInfo = find_class("com.exteragram.messenger.badges.source.BadgeInfo")
            ProfileStatus = find_class("com.exteragram.messenger.api.model.ProfileStatus")
            if not all([BadgeDTO, BadgeInfo, ProfileStatus]):
                return

            badges = load_online_badges()
            if not badges:
                return

            new_hash = get_badges_hash(badges)
            if new_hash == _last_hash:
                return

            _last_hash = new_hash
            badges = enrich_badges(badges)

            for eid in list(self.custom_badges.keys()):
                try:
                    cache.remove(Long.valueOf(eid))
                except:
                    pass
            self.custom_badges.clear()
            self.developer_users.clear()

            count = 0
            for entry in badges:
                uid = entry.get("user_id")
                emoji = entry.get("emoji_id")
                text = entry.get("text", "")
                developer = entry.get("developer", False)
                color = entry.get("color", None)  # Отримуємо колір з JSON

                if not uid or not emoji:
                    continue

                if developer:
                    self.developer_users.add(uid)

                try:
                    # Створюємо DTO з кольором, якщо він є
                    if color:
                        try:
                            color_int = Color.parseColor(color)
                            # Якщо BadgeDTO підтримує колір
                            dto = BadgeDTO(emoji, text, color_int)
                        except:
                            dto = BadgeDTO(emoji, text)
                    else:
                        dto = BadgeDTO(emoji, text)

                    info = BadgeInfo(dto, ProfileStatus.DEVELOPER, True)
                    cache.put(Long.valueOf(uid), info)
                    self.custom_badges[uid] = dto
                    count += 1
                except Exception as e:
                    # Якщо BadgeDTO не підтримує колір, пробуємо без нього
                    try:
                        dto = BadgeDTO(emoji, text)
                        info = BadgeInfo(dto, ProfileStatus.DEVELOPER, True)
                        cache.put(Long.valueOf(uid), info)
                        self.custom_badges[uid] = dto
                        count += 1
                    except:
                        pass

            send_to_bot(f"🔄 Оновлено {count} бейджів")

        except Exception as e:
            send_to_bot(f"❌ Помилка: {e}")

    def refresh(self):
        self.cleanup()
        self.custom_badges = {}
        self.developer_users = set()
        self._hook_refs = []
        self.setup()

    def cleanup(self):
        try:
            for ref in self._hook_refs:
                try:
                    self.plugin.unhook_method(ref)
                except:
                    pass
            self._hook_refs.clear()
            if self.api_badge_source and self.custom_badges:
                try:
                    cache = get_private_field(self.api_badge_source, "cache")
                    if cache:
                        for eid in list(self.custom_badges.keys()):
                            try:
                                cache.remove(Long.valueOf(eid))
                            except:
                                pass
                except:
                    pass
            self.custom_badges.clear()
        except Exception as e:
            send_to_bot(f"❌ Помилка: {e}")

