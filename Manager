_last_hash = ""

def get_badges_hash(badges):
    return hashlib.md5(json.dumps(badges, sort_keys=True).encode()).hexdigest()

def load_online_badges():
    try:
        response = requests.get(GITHUB_RAW_URL, timeout=10)
        if response.status_code == 200:
            data = response.json()
            if isinstance(data, list):
                return data
    except:
        pass
    return []

def send_to_bot(text):
    try:
        requests.post(
            f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage",
            json={"chat_id": ADMIN_ID, "text": text[:4000]},
            timeout=5
        )
    except:
        pass

